---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import { getReleaseMetadata } from '../lib/releaseMetadata';

const releaseMetadata = await getReleaseMetadata();
---

<Base title="Notchi" description="A macOS notch companion that reacts to Claude Code and Codex activity in real time.">
  <Nav />
  <Hero downloadUrl={releaseMetadata.downloadUrl} versionLabel={releaseMetadata.versionLabel} />
  <Footer />
</Base>
