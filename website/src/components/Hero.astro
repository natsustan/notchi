---
interface Props {
  downloadUrl: string;
  versionLabel?: string;
}

const { downloadUrl, versionLabel } = Astro.props;
---

<section class="hero">
  <img src="/app-icon.webp" alt="Notchi app icon" class="app-icon" width="208" height="208" fetchpriority="high" />
  <div class="hero-copy">
    <h1>Notchi</h1>
    <p class="tagline">Your Claude Code and Codex companion, living in the notch. It reacts to every thought, tool call, and error in real time.</p>
  </div>
  <div class="btn-wrap">
    <a href={downloadUrl} class="btn">
      <svg class="apple-logo" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 814 1000">
        <path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57.8-155.5-127.4c-58.8-82-106.4-211.6-106.4-335.2 0-191.6 124.5-293.2 247.2-293.2 65.2 0 119.6 42.8 160.5 42.8 39 0 99.7-45.4 174.3-45.4 28.2 0 129.6 2.6 196.4 99.4zM554.1 159.4c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.2 32.4-55.7 83.6-55.7 135.5 0 7.8.6 15.6 1.3 18.2 2.6.6 6.4 1.3 10.2 1.3 45.4 0 103.2-30.4 140.1-71.4z"/>
      </svg>
      Download for macOS
    </a>
  </div>
  {versionLabel && <p class="badge"><span>{versionLabel}</span></p>}
</section>

<script>
  const SHAPES = ['star4', 'star6', 'cross', 'circle', 'dot', 'diamond', 'ring'];
  const COLORS = [
    '#f47b38', '#ff9a5d', '#ffb180',
    '#a78bfa', '#818cf8',
    '#34d399', '#6ee7b7',
    '#f472b6', '#fb7185',
    '#60a5fa', '#38bdf8',
    '#fbbf24', '#facc15',
  ];

  const SHAPE_PATHS = {
    star4: 'M8 0L9.5 6.5 16 8 9.5 9.5 8 16 6.5 9.5 0 8 6.5 6.5Z',
    star6: 'M8 0L9.2 5.5 14 2 10.5 6.8 16 8 10.5 9.2 14 14 9.2 10.5 8 16 6.8 10.5 2 14 5.5 9.2 0 8 5.5 6.8 2 2 6.8 5.5Z',
    cross: 'M7 0h2v16H7zM0 7h16v2H0z',
    diamond: 'M8 2L14 8 8 14 2 8Z',
  };
  const CIRCLE_SHAPES = {
    circle: { r: 3.5, sw: 1.5, fill: false },
    dot: { r: 2.5, sw: 0, fill: true },
    ring: { r: 5, sw: 1, fill: false },
  };

  const MAX_PARTICLES = 40;
  let liveCount = 0;

  function createSparkleEl(shape, color, size) {
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('width', String(size));
    svg.setAttribute('height', String(size));
    svg.setAttribute('viewBox', '0 0 16 16');

    if (SHAPE_PATHS[shape]) {
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', SHAPE_PATHS[shape]);
      if (shape === 'diamond') {
        path.setAttribute('stroke', color);
        path.setAttribute('stroke-width', '1.5');
        path.setAttribute('fill', 'none');
      } else {
        path.setAttribute('fill', color);
      }
      svg.appendChild(path);
    } else {
      const c = CIRCLE_SHAPES[shape];
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', '8');
      circle.setAttribute('cy', '8');
      circle.setAttribute('r', String(c.r));
      if (c.fill) {
        circle.setAttribute('fill', color);
      } else {
        circle.setAttribute('stroke', color);
        circle.setAttribute('stroke-width', String(c.sw));
        circle.setAttribute('fill', 'none');
      }
      svg.appendChild(circle);
    }

    const el = document.createElement('div');
    el.className = 'sparkle';
    el.appendChild(svg);
    return el;
  }

  function spawnSparkle(container, rect) {
    if (liveCount >= MAX_PARTICLES) return;

    const shape = SHAPES[Math.floor(Math.random() * SHAPES.length)];
    const color = COLORS[Math.floor(Math.random() * COLORS.length)];
    const size = 6 + Math.random() * 12;

    const padX = 60;
    const padY = 50;
    const x = -padX + Math.random() * (rect.width + padX * 2);
    const y = -padY + Math.random() * (rect.height + padY * 2);

    const inBtn = x > 0 && x < rect.width && y > 0 && y < rect.height;
    if (inBtn && Math.random() > 0.3) return;

    const el = createSparkleEl(shape, color, size);
    el.style.left = `${x}px`;
    el.style.top = `${y}px`;

    const drift = -20 + Math.random() * 40;
    const rise = -15 + Math.random() * -25;
    const dur = 600 + Math.random() * 900;
    const rot = Math.random() * 180 - 90;

    el.style.setProperty('--drift', `${drift}px`);
    el.style.setProperty('--rise', `${rise}px`);
    el.style.setProperty('--rot', `${rot}deg`);
    el.style.animationDuration = `${dur}ms`;

    liveCount++;
    container.appendChild(el);
  }

  const wrap = document.querySelector('.btn-wrap');
  if (wrap) {
    let interval = null;

    wrap.addEventListener('animationend', (e) => {
      if (e.target.classList.contains('sparkle')) {
        e.target.remove();
        liveCount--;
      }
    });

    wrap.addEventListener('mouseenter', () => {
      const rect = wrap.getBoundingClientRect();
      clearInterval(interval);
      for (let i = 0; i < 8; i++) setTimeout(() => spawnSparkle(wrap, rect), i * 50);
      interval = setInterval(() => spawnSparkle(wrap, rect), 80);
    });

    wrap.addEventListener('mouseleave', () => {
      clearInterval(interval);
      interval = null;
    });
  }
</script>
